# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=argloveweb

# Security (required — min 32 characters)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Server
PORT=5000
NODE_ENV=development

# CORS — comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Only enable in local dev when Razorpay keys are not configured (never in production)
FORCE_MOCK_RAZORPAY=false

# Seed script (optional — random passwords generated if omitted)
# SEED_ADMIN_EMAIL=admin@arglove.com
# SEED_ADMIN_PASSWORD=
# SEED_CUSTOMER_EMAIL=customer@example.com
# SEED_CUSTOMER_PASSWORD=

# SMTP (optional — password reset emails)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM="ARGLOVE" <no-reply@arglove.com>
